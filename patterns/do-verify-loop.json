{
  "meta": {
    "name": "do-verify-loop",
    "stage": "orchestrate (làm/kiểm)",
    "entry": "__P__builder",
    "exits": [
      { "label": "pass", "node": "__P__done" }
    ],
    "routers": ["__P__verdict"],
    "router_labels": {
      "__P__verdict": ["pass", "fail"]
    },
    "fallback": "__P__verdict --fail--> __P__builder (back-edge); max_steps là cầu dao cứng",
    "note": "Placeholder __P__ CHỈ ở node.id + edge.from/to. Data key (input/output_key) là tên thật, host tự lo namespace khi ghép nhiều pattern. Host bind agent mỗi node (convention agents/<stamped-id>.md) + cấp name/entry/max_steps."
  },
  "nodes": [
    { "id": "__P__builder", "type": "work",   "input": "{{user_request}}\n{{verdict}}", "output_key": "build" },
    { "id": "__P__tester",  "type": "work",   "input": "{{build}}",                     "output_key": "test" },
    { "id": "__P__verdict", "type": "router", "input": "{{test}}",                       "output_key": "verdict" },
    { "id": "__P__done",    "type": "work",   "input": "{{build}}\n{{test}}",            "output_key": "result" }
  ],
  "edges": [
    { "from": "__P__builder", "to": "__P__tester" },
    { "from": "__P__tester",  "to": "__P__verdict" },
    { "from": "__P__verdict", "to": "__P__builder", "when": "fail" },
    { "from": "__P__verdict", "to": "__P__done",    "when": "pass" }
  ]
}
