{
  "name": "hq-tester",
  "entry": "work",
  "max_steps": 5,
  "nodes": [
    { "id": "work",   "agent": "agents/work.md",   "input": "{{user_request}}", "output_key": "result" },
    { "id": "record", "agent": "agents/record.md", "input": "Bài học từ lần chạy: {{result}}", "output_key": "lesson", "memory_write": "context" }
  ],
  "edges": [
    { "from": "work", "to": "record" }
  ],
  "trial": [
    { "observe": "result", "expect": { "kind": "non-empty" } }
  ]
}
