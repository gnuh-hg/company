{
  "name": "broken-web",
  "entry": "pm",
  "max_steps": 12,
  "nodes": [
    {
      "id": "pm",
      "agent": "agents/pm.md",
      "input": "{{user_request}}",
      "output_key": "pm_scope"
    },
    {
      "id": "ux",
      "agent": "agents/ux.md",
      "input": "{{pm_scope}}",
      "output_key": "ux_flow"
    },
    {
      "id": "frontend-developer",
      "agent": "agents/frontend-developer.md",
      "input": "{{ux_flow}}",
      "output_key": "fe_impl"
    },
    {
      "id": "qa-functional",
      "agent": "agents/qa-functional.md",
      "input": "{{fe_impl}}\n{{pm_scope}}",
      "output_key": "qa_report"
    }
  ],
  "edges": [
    {
      "from": "pm",
      "to": "ux"
    },
    {
      "from": "ux",
      "to": "frontend-develper"
    },
    {
      "from": "frontend-developer",
      "to": "qa-functional"
    }
  ],
  "trial": [
    {
      "observe": "qa_report",
      "expect": {
        "kind": "non-empty"
      }
    }
  ]
}
