{
  "name": "p-brain",
  "entry": "rg_researcher",
  "max_steps": 30,
  "nodes": [
    {
      "id": "rg_researcher",
      "agent": "agents/rg_researcher.md",
      "type": "work",
      "input": "{{user_request}}",
      "output_key": "research"
    },
    {
      "id": "rg_gate",
      "agent": "agents/rg_gate.md",
      "input": "{{research}}",
      "output_key": "research_gate"
    },
    {
      "id": "cg_gate",
      "agent": "agents/cg_gate.md",
      "input": "{{user_request}}",
      "output_key": "clarify_gate"
    },
    {
      "id": "pd_planner",
      "agent": "agents/pd_planner.md",
      "type": "work",
      "input": "{{user_request}}",
      "output_key": "plan"
    },
    {
      "id": "pd_classify",
      "agent": "agents/pd_classify.md",
      "input": "{{plan}}",
      "output_key": "plan_depth"
    },
    {
      "id": "dv_builder",
      "agent": "agents/dv_builder.md",
      "type": "work",
      "input": "{{user_request}}\n{{verdict}}",
      "output_key": "build"
    },
    {
      "id": "dv_tester",
      "agent": "agents/dv_tester.md",
      "type": "work",
      "input": "{{build}}",
      "output_key": "test"
    },
    {
      "id": "dv_verdict",
      "agent": "agents/dv_verdict.md",
      "input": "{{test}}",
      "output_key": "verdict"
    },
    {
      "id": "eg_gate",
      "agent": "agents/eg_gate.md",
      "input": "{{user_request}}",
      "output_key": "escalate_gate"
    },
    {
      "id": "eg_user",
      "agent": "agents/eg_user.md",
      "type": "work",
      "input": "{{user_request}}",
      "output_key": "escalation_report"
    },
    {
      "id": "record",
      "agent": "agents/record.md",
      "type": "work",
      "input": "{{user_request}}",
      "output_key": "record_result"
    }
  ],
  "edges": [
    {
      "from": "rg_researcher",
      "to": "rg_gate"
    },
    {
      "from": "rg_gate",
      "to": "pd_planner",
      "when": "enough"
    },
    {
      "from": "rg_gate",
      "to": "cg_gate",
      "when": "need_clarify"
    },
    {
      "from": "cg_gate",
      "to": "pd_planner",
      "when": "ok"
    },
    {
      "from": "cg_gate",
      "to": "eg_gate",
      "when": "missing_input"
    },
    {
      "from": "pd_planner",
      "to": "pd_classify"
    },
    {
      "from": "pd_classify",
      "to": "dv_builder",
      "when": "long"
    },
    {
      "from": "pd_classify",
      "to": "dv_builder",
      "when": "short"
    },
    {
      "from": "dv_builder",
      "to": "dv_tester"
    },
    {
      "from": "dv_tester",
      "to": "dv_verdict"
    },
    {
      "from": "dv_verdict",
      "to": "record",
      "when": "pass"
    },
    {
      "from": "dv_verdict",
      "to": "pd_planner",
      "when": "fail"
    },
    {
      "from": "dv_verdict",
      "to": "pd_planner",
      "when": "clarify"
    },
    {
      "from": "dv_verdict",
      "to": "eg_gate",
      "when": "escalate"
    },
    {
      "from": "eg_gate",
      "to": "record",
      "when": "resolved"
    },
    {
      "from": "eg_gate",
      "to": "eg_user",
      "when": "escalate"
    }
  ]
}
