{
  "name": "hq-coo",
  "entry": "coo",
  "max_steps": 5,
  "nodes": [
    { "id": "coo",          "agent": "agents/coo.md",          "type": "router", "input": "{{user_request}}", "output_key": "route" },
    { "id": "build_path",   "agent": "agents/build-path.md",   "input": "{{route}}", "output_key": "result" },
    { "id": "fix_path",     "agent": "agents/fix-path.md",     "input": "{{route}}", "output_key": "result" },
    { "id": "unclear_path", "agent": "agents/unclear-path.md", "input": "{{route}}", "output_key": "result" }
  ],
  "edges": [
    { "from": "coo", "to": "build_path",   "when": "build" },
    { "from": "coo", "to": "fix_path",     "when": "fix" },
    { "from": "coo", "to": "unclear_path", "when": "unclear" }
  ]
}
