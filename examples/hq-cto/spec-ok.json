{
  "name": "hq-tiny-api",
  "entry": "pm",
  "max_steps": 12,
  "roles": [
    { "id": "pm",  "role": "pm",            "input": "{{user_request}}", "output_key": "spec" },
    { "id": "api", "role": "api-developer", "input": "{{spec}}",         "output_key": "api_design" }
  ],
  "patterns": [
    { "name": "do-verify-loop", "prefix": "dv" }
  ],
  "edges": [
    { "from": "pm",  "to": "api" },
    { "from": "api", "to": "dv_builder" }
  ],
  "trial": [
    { "observe": "result", "expect": { "kind": "non-empty" } }
  ]
}
